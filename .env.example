# LedgerFlow — copy to .env and fill values
# .env is in .git/info/exclude — NEVER committed

APP_NAME=ledger-flow
SPRING_PROFILES_ACTIVE=local

DATABASE_URL=jdbc:postgresql://localhost:5432/ledgerflow
DATABASE_USER=CHANGE_ME
DATABASE_PASSWORD=CHANGE_ME

# Admin endpoints protection
ADMIN_API_KEY=CHANGE_ME_USE_RANDOM_32_CHARS
