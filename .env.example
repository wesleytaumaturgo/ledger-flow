# LedgerFlow — Required Environment Variables
# Copy this file to .env and fill in real values before running.
# .env is intentionally NOT tracked by git (see .git/info/exclude).

APP_NAME=ledger-flow
SPRING_PROFILES_ACTIVE=local

# PostgreSQL Database
# Format: jdbc:postgresql://<host>:<port>/<database>
DATABASE_URL=jdbc:postgresql://localhost:5432/ledgerflow
DATABASE_USER=ledgerflow_app
DATABASE_PASSWORD=CHANGE_ME

# GitHub Actions CI only — not needed for local development
# NVD_API_KEY=<get from https://nvd.nist.gov/developers/request-an-api-key>
